<!DOCTYPE html>
<html>
<head>
<title>Spinner</title>
</head>

<body>

<h1 id="result">Click a button</h1>

<button onclick="showRed()">Black</button>
<button onclick="showBlack()">Red</button>

<script>
function showRed() {
  document.getElementById("result").textContent = "Red";
}

function showBlack() {
  document.getElementById("result").textContent = "Black";
}
</script>

</body>
</html>
